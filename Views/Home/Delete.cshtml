@model HK_Registration.Models.HKClass

@{
    ViewData["Title"] = "Delete Class";
}

<h2>@ViewData["Title"]</h2>
<hr />

<h4>Are you sure you want to delete this class?</h4>

<br />

<dl class="row">

    <dt class="col-sm-2">
        Name
    </dt>
    <dd class="col-sm-10">
        @Model.Name
    </dd>

    <dt class="col-sm-2">
        Number
    </dt>
    <dd class="col-sm-10">
        @Model.Number
    </dd>

    <dt class="col-sm-2">
        Department
    </dt>
    <dd class="col-sm-10">
        @Model.Department
    </dd>

    <dt class="col-sm-2">
        Credit
    </dt>
    <dd class="col-sm-10">
        @Model.Credit
    </dd>

    <dt class="col-sm-2">
        Capacity
    </dt>
    <dd class="col-sm-10">
        @Model.Capacity
    </dd>

</dl>

<form asp-action="Delete">

    <input type="hidden" asp-for="CourseID" />

    <button type="submit"
            class="btn btn-danger rounded-pill">
        Delete
    </button>

    <a asp-action="Index"
       class="btn btn-secondary rounded-pill">
        Cancel
    </a>

</form>