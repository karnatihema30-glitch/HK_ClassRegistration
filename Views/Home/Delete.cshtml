@model HK_Registration.Models.HKClass

<h2>Delete Class</h2>

<h4>Are you sure you want to delete this class?</h4>

<div>
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Number:</strong> @Model.Number</p>
    <p><strong>Department:</strong> @Model.Department</p>
    <p><strong>Credit:</strong> @Model.Credit</p>
    <p><strong>Capacity:</strong> @Model.Capacity</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="CourseID" />
    <button type="submit">Delete</button>
    <a asp-action="Index">Cancel</a>
</form>